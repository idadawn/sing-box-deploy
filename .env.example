# ============================================================
# sing-box 部署配置文件
# 使用方法: cp .env.example .env，然后填写实际值
# 注意: 值中不能包含 # 字符（解析器不支持行内注释）
# ============================================================

# ----------------------------------------------------------
# 1. T 中继服务器域名配置（需在 Cloudflare 中添加 A 记录指向 T 机 IP）
#    必须设置为 DNS Only（灰云），不能开启代理（橙云）
# ----------------------------------------------------------
TROJAN_DOMAIN=tj.yourdomain.com
HYSTERIA_DOMAIN=hy2.yourdomain.com

# ----------------------------------------------------------
# 2. Cloudflare API Token（用于 ACME DNS-01 证书申请）
# ----------------------------------------------------------
# Zone:DNS:Edit 权限（必填）
CF_DNS_EDIT_TOKEN=your_dns_edit_token_here

# Zone:Zone:Read 权限（可选，不填也能运行）
CF_ZONE_READ_TOKEN=your_zone_read_token_here

# Let's Encrypt 注册邮箱
ACME_EMAIL=your_email@example.com

# ----------------------------------------------------------
# 3. 私有 ISP 清单
#    复制 isp-list.example.tsv 为 isp-list.tsv 后填写。
#    TSV 列顺序固定：编号、IP、HTTP端口、SOCKS5端口、用户、密码、到期时间。
#    行顺序决定入站端口槽位；为保持现有订阅稳定，请勿随意重排或删除旧行。
# ----------------------------------------------------------
ISP_LIST_FILE=isp-list.tsv
ISP_PORT_STEP=10000

# AI 域名始终走当前订阅对应的 ISP；留空使用脚本内置清单。
AI_ISP_DOMAINS=

# 可选：让视频/CDN/软件包下载从当前服务器公网 IP 直出。
DIRECT_BULK_ENABLED=false
# 留空使用脚本内置清单；自定义时用逗号分隔。
DIRECT_BULK_DOMAINS=

# 每天从 Loyalsoldier release 分支同步规则并发布到当前 SUB_DOMAIN/rules。
# 客户端规则地址留空即可使用自托管镜像；仅在需要外部镜像时覆盖。
CLASH_RULESET_BASE_URL=
CLASH_RULESET_UPSTREAM_REPO=https://github.com/Loyalsoldier/clash-rules.git
CLASH_RULESET_UPSTREAM_BRANCH=release

# ----------------------------------------------------------
# 4. 入站认证密码（建议使用 openssl rand -base64 32 生成）
# ----------------------------------------------------------
TROJAN_PASSWORD=your_trojan_password_here
HYSTERIA_PASSWORD=your_hysteria_password_here
HYSTERIA_OBFS_PASSWORD=your_obfs_password_here

# ----------------------------------------------------------
# 5. 端口配置
# ----------------------------------------------------------
# 清单第 1 行使用以下端口；后续行按 ISP_PORT_STEP 递增。
TROJAN_PORT=443
HYSTERIA_PORT=8443

# ----------------------------------------------------------
# 6. Hysteria2 带宽限制（Mbps，按实际线路填写）
# ----------------------------------------------------------
HYSTERIA_UP_MBPS=100
HYSTERIA_DOWN_MBPS=100

# ----------------------------------------------------------
# 7. 日志级别（trace / debug / info / warn / error）
# ----------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------
# 8. 防火墙（UFW）配置
# ----------------------------------------------------------
ENABLE_UFW=true
SSH_PORT=22

# ----------------------------------------------------------
# 9. Cloudflare Pages 订阅托管（自动部署）
#     创建 Token: https://dash.cloudflare.com/profile/api-tokens
#     权限要求: Cloudflare Pages:Edit + Account:Read
# ----------------------------------------------------------
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_account_id_here
CF_PAGES_PROJECT=sub-converter

# 订阅域名（在 Cloudflare Pages 中绑定的自定义域名）
SUB_DOMAIN=sub.yourdomain.com

# 节点别名前缀，仅用于订阅展示
SUB_REMARKS=US

# ----------------------------------------------------------
# 10. Clash 配置
# ----------------------------------------------------------
# external-controller 认证密钥（留空则每次自动生成随机值）
SECRET=

# 隐藏订阅路径（保护订阅地址；留空则每次自动生成随机值）
# 建议设置固定值，避免每次部署后路径变化
HIDDEN_SUB_PATH=

# ----------------------------------------------------------
# 11. 出口异常邮件告警（可选）
# ----------------------------------------------------------
SMTP_ALERT_ENABLED=false
SMTP_HOST=smtp.sina.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
